# ── SentinelX .gitignore ─────────────────────────────────────

# Virtual environments
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Local database (created at runtime)
*.db
sentinelx.db

# Environment files
# .env is tracked for this project
.env.local

# IDE & editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Docker exports (large files)
*.tar

# Logs
*.log

# Terraform state (contains sensitive info)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Gemini / agent data
.gemini/

.env
