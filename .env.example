# ═══════════════════════════════════════════════════════════════
# SentinelX — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── AlienVault OTX ───────────────────────────────────────────────
# Get your API key at: https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# ── JWT Authentication ───────────────────────────────────────────
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET_KEY=sentinelx-super-secret-key-change-in-production

# ── Database ─────────────────────────────────────────────────────
# Local:  sqlite:///./sentinelx.db
# Docker: sqlite:////data/sentinelx.db  (volume-mounted)
DATABASE_URL=sqlite:///./sentinelx.db

# ── Backend URL ──────────────────────────────────────────────────
# Local:  http://localhost:8003
# Docker: http://backend:8003  (set automatically by docker-compose)
BACKEND_URL=http://localhost:8003

# ── Admin Credentials (used during initial DB seed) ──────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=SentinelX@2024
ADMIN_EMAIL=admin@sentinelx.local

# ── Analyst Credentials (used during initial DB seed) ────────────
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=analyst123
ANALYST_EMAIL=analyst@sentinelx.local

# ── Docker Port Mapping (optional, defaults shown) ───────────────
# BACKEND_PORT=8003
# FRONTEND_PORT=8503

# ── Debug Mode ───────────────────────────────────────────────────
DEBUG=false
